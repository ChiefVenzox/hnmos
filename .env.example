# HNMos local environment template.
# Copy this file to .env for machine-specific settings.
# .env is intentionally ignored by git.

# Optional cross compiler prefix used by the Makefile.
# Example: CROSS_COMPILE=i686-elf-
CROSS_COMPILE=

# Host-side QEMU AI bridge. Never commit a real key.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
