{
  "manifest_version": 1,
  "app_id": "org.hnmos.hn-ai-lab",
  "name": "hn-ai-lab",
  "type": "ai_assistant_app",
  "entry": "main.hnl",
  "runtime": "hnlang",
  "description": "Safe AI Runtime Interface experiment app for HNMos.",
  "permissions": [
    {
      "capability": "read.system_status",
      "scope": "system.summary",
      "reason": "allow AI to explain high-level system status"
    },
    {
      "capability": "read.events.public",
      "scope": "event_snapshot.public",
      "reason": "allow AI to explain public event patterns"
    },
    {
      "capability": "read.fs.metadata",
      "scope": "/workspace",
      "reason": "allow AI to inspect workspace metadata only"
    },
    {
      "capability": "write.workspace.hnlang",
      "scope": "/workspace/*.hn",
      "reason": "write reviewable HNLang drafts without system authority"
    },
    {
      "capability": "read.build.log",
      "scope": "/workspace/.hnmos/build.log",
      "reason": "explain workspace build failures"
    },
    {
      "capability": "run.workspace.build",
      "scope": "/workspace",
      "reason": "request an approved workspace-only build"
    }
  ],
  "shell": {
    "command": "hn app run hn-ai-lab",
    "aliases": [
      "hn-ai-lab",
      "hn ai lab"
    ]
  },
  "ui": {
    "mode": "ai_studio",
    "panels": [
      "assistant_panel",
      "task_monitor"
    ]
  },
  "ai": {
    "uses_ai": true,
    "context_policy": "public_and_workspace_only",
    "requires_user_approval_for_actions": true,
    "credential_policy": "volatile_provider_handoff",
    "forbidden_targets": [
      "kernel",
      "boot",
      "policy",
      "drivers",
      "audit"
    ]
  }
}
