{
  "manifest_version": 1,
  "app_id": "org.hnmos.example.app",
  "name": "hn-example",
  "type": "task_app",
  "entry": "main.hnl",
  "runtime": "hnlang",
  "description": "Example HNMos task application.",
  "permissions": [
    {
      "capability": "read.system_status",
      "scope": "system.summary",
      "reason": "show basic system status"
    }
  ],
  "shell": {
    "command": "hn app run hn-example",
    "aliases": [
      "hn-example"
    ]
  },
  "ui": {
    "mode": "console",
    "panels": []
  },
  "ai": {
    "uses_ai": false,
    "context_policy": "none"
  }
}
